# Browser-visible development endpoints.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FLOWGRAPH_URL=http://localhost:8182
NEXT_PUBLIC_TEMPORAL_UI_URL=http://localhost:8233

# Application runtime settings.
APP_ENVIRONMENT=development
ENABLE_DEVELOPMENT_ENDPOINTS=true
API_IMAGE=flowgraph-ai-api:development
WORKFLOW_WORKER_IMAGE=flowgraph-ai-workflow-worker:development

# Redis stores disposable cache entries only. Persistence is disabled, so
# application correctness must not depend on retained keys.
REDIS_IMAGE=redis:8.2.7-alpine
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=flowgraph:dev
REDIS_MAXMEMORY=256mb
REDIS_CONNECT_TIMEOUT_SECONDS=1
REDIS_OPERATION_TIMEOUT_SECONDS=2
REDIS_MAX_CONNECTIONS=20
REDIS_DEFAULT_TTL_SECONDS=300

# Temporal development history is retained in the temporal_data Docker volume.
# The pinned image is suitable for local development, not production.
TEMPORAL_IMAGE=temporalio/temporal@sha256:2c344b4a39b4489fc6944db095f628f0c30659836faf11780a4dc435599e80e3
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8233
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=flowgraph-ai
TEMPORAL_TASK_QUEUE=platform-workflows
TEMPORAL_CONNECT_TIMEOUT_SECONDS=5
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=2

# Development-only Kratos runner. It executes API-supplied Python in a shared
# jobs volume and must not be exposed to untrusted clients.
KRATOS_IMAGE=kratosmultiphysics/kratos-image-ci-ubuntu-22-04:latest
KRATOS_VERSION=10.4.3
# The published CI image is single-platform. Keep amd64 on Apple Silicon.
KRATOS_PLATFORM=linux/amd64
RUNNER_POLL_SECONDS=1
# Optional Python path override for a custom Kratos installation made available
# in the runner image or through an additional bind mount.
KRATOS_PYTHONPATH=
