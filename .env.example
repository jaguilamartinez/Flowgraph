NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FLOWGRAPH_URL=http://localhost:8182
KRATOS_IMAGE=kratosmultiphysics/kratos-image-ci-ubuntu-22-04:latest
KRATOS_VERSION=10.4.3
# The published CI image is single-platform. Keep amd64 on Apple Silicon.
KRATOS_PLATFORM=linux/amd64
RUNNER_POLL_SECONDS=1
# Set this when replacing the wheel with a bind-mounted local Kratos build.
KRATOS_PYTHONPATH=
